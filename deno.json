{
  "name": "dn_phg_music_server",
  "version": "1.0.0",
  "description": "洛雪音乐第三方音源后台 - Deno Deploy 实现",
  "type": "module",
  "exports": "./main.ts",
  "nodeModulesDir": "auto",
  "runtime": "deno",
  "scripts": {
    "start": "deno run --allow-all --watch main.ts",
    "dev": "deno run --allow-all --watch main.ts",
    "check": "deno check main.ts",
    "lint": "deno lint",
    "bundle": "deno bundle main.ts bundle.js"
  },
  "imports": {
    "$std/": "https://deno.land/std@0.216.0/"
  },
  "compilerOptions": {
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "lib": ["deno.ns", "deno.unstable", "dom"]
  }
}
